{
  "name": "@omnara/server",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "node dist/main",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\"",
    "seed": "ts-node -r tsconfig-paths/register src/seeders/seed.ts",
    "mikro-orm": "mikro-orm"
  },
  "dependencies": {
    "@mikro-orm/core": "^7.1.4",
    "@mikro-orm/migrations": "^7.1.4",
    "@mikro-orm/nestjs": "^7.0.2",
    "@mikro-orm/postgresql": "^7.1.4",
    "@mikro-orm/reflection": "^7.1.4",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@nestjs/common": "11.1.26",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "11.1.26",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "11.1.26",
    "@nestjs/throttler": "^6.5.0",
    "argon2": "^0.44.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "helmet": "^8.2.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^14.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@mikro-orm/cli": "^7.1.4",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "11.1.26",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/helmet": "^4.0.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^11.0.0",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0"
  },
  "mikro-orm": {
    "configPaths": [
      "./src/database/mikro-orm.config.ts"
    ],
    "useTsNode": true
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.test.json"
        }
      ]
    },
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1",
      "^@mikro-orm/(.*)$": "<rootDir>/test-helpers/mikro-orm-mock"
    },
    "transformIgnorePatterns": [],
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
