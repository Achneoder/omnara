{
  "name": "omnara",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @omnara/server start:dev & pnpm --filter @omnara/client dev & pnpm --filter @omnara/dashboard dev",
    "seed:softeis-kai": "pnpm exec tsx scripts/seed-softeis-kai.ts",
    "preview:softeis-kai": "npx serve preview -p 5175",
    "storybook": "pnpm --filter @omnara/ui storybook",
    "build-storybook": "pnpm --filter @omnara/ui build-storybook",
    "prepare": "husky",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,svelte,json,md,yaml,css}\"",
    "test": "pnpm -r test",
    "build": "pnpm -r build"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-svelte": "^3.0.0",
    "globals": "^15.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "3.4.2",
    "prettier-plugin-svelte": "^4.0.0",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "svelte-eslint-parser": "^1.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0"
  },
  "packageManager": "pnpm@11.6.0",
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
